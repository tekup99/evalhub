# ==============================================================================
# EvalHub Unified Configuration (Optimized for 2x H200 141GB)
# ==============================================================================
BASE_MODELS="Qwen/Qwen3.5-4B-Base"
JUDGE_MODELS="Qwen/Qwen3.5-35B-A3B"
BENCHMARKS="aime2026"
HF_TOKEN=""
PORT=30000

# ==============================================================================
# Base Model (4B) Config
# Strategy: DP=2 (Data Parallelism) for massive throughput
# ==============================================================================
BASE_TEMPERATURES="0.6"
BASE_N_SAMPLES=64
BASE_TOP_P=0.95
BASE_MAX_COMPLETION_TOKENS=16384
BASE_FREQUENCY_PENALTY=0.0
BASE_PRESENCE_PENALTY=0.0
BASE_NUM_WORKERS=256      # Scaled up for DP=2 to fully saturate both GPUs
BASE_TIMEOUT=172800

BASE_STOP=""
BASE_SYSTEM_PROMPT=""
BASE_OVERRIDE_ARGS=""
BASE_ENABLE_MULTITURN=false
BASE_MAX_TURNS=3
BASE_TOOL_CONFIG=""
BASE_CALLBACK=""
BASE_RESUME=false         # Disabled per constraints

# Maxed out Base Resources
BASE_SLURM_CPUS=64
BASE_SLURM_MEM="512G"
BASE_SLURM_GRES="gpu:h200:2"
BASE_SLURM_TIME="48:00:00"
BASE_SLURM_NODELIST="nsdl2"

# ==============================================================================
# Judge Model (35B) Config 
# Strategy: TP=2 (Tensor Parallelism) for unified KV Cache pool during sweeps
# ==============================================================================
JUDGE_TEMPERATURES="0.0 0.3 0.6 1.0 1.2"
JUDGE_N_SAMPLES=3
JUDGE_TOP_P=0.95
JUDGE_MAX_COMPLETION_TOKENS=16384
JUDGE_FREQUENCY_PENALTY=0.0
JUDGE_PRESENCE_PENALTY=0.0
JUDGE_NUM_WORKERS=128     # Scaled for TP=2 capacity limits
JUDGE_TIMEOUT=172800

JUDGE_STOP=""
JUDGE_SYSTEM_PROMPT=""
JUDGE_OVERRIDE_ARGS=""
JUDGE_ENABLE_MULTITURN=false
JUDGE_MAX_TURNS=3
JUDGE_TOOL_CONFIG=""
JUDGE_CALLBACK=""
JUDGE_RESUME=false        # Disabled per constraints

# Maxed out Judge Resources
JUDGE_SLURM_CPUS=64
JUDGE_SLURM_MEM="512G"
JUDGE_SLURM_GRES="gpu:h200:2"
JUDGE_SLURM_TIME="48:00:00"
JUDGE_SLURM_NODELIST="nsdl2"

# ==============================================================================
# Lightweight Worker Resources
# ==============================================================================
EXTRACT_SLURM_CPUS=16
EXTRACT_SLURM_MEM="64G"
EXTRACT_SLURM_TIME="04:00:00"

POST_SLURM_CPUS=16
POST_SLURM_MEM="64G"
POST_SLURM_TIME="04:00:00"