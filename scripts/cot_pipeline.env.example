# ----------------------------------------------------------------------------
# CoT-Pass@K pipeline configuration. Copy to cot_pipeline.env and edit.
# Any value left blank falls back to the script defaults.
# ----------------------------------------------------------------------------

# Required ------------------------------------------------------------------
TARGET_MODEL="Qwen/Qwen3-7B-Instruct"
JUDGE_MODEL="Qwen/Qwen3-32B-Instruct"
BENCHMARK="aime2025"

# Model state per role: base | non-think | think -----------------------------
TARGET_STATE="non-think"
JUDGE_STATE="think"

# Target sampling parameters -------------------------------------------------
TARGET_TEMPERATURE=0.6
TARGET_TOP_P=0.95
TARGET_N_SAMPLES=8
TARGET_MAX_COMPLETION_TOKENS=16384
TARGET_NUM_WORKERS=256
TARGET_TIMEOUT=3600
TARGET_FREQUENCY_PENALTY=0
TARGET_PRESENCE_PENALTY=0
TARGET_STOP=
TARGET_SYSTEM_PROMPT=
TARGET_OVERRIDE_ARGS=
TARGET_TOOL_CONFIG=
TARGET_CALLBACK=
TARGET_MAX_TURNS=3
TARGET_ENABLE_MULTITURN=false
TARGET_RESUME=false
TARGET_PARALLEL_COUNT=1

# Judge sampling parameters -------------------------------------------------
JUDGE_TASK="cot_judge"           # cot_judge | cot_judge_tr | cot_judge_pt
JUDGE_TEMPERATURE=0.6
JUDGE_TOP_P=0.95
JUDGE_N_SAMPLES=3
JUDGE_MAX_COMPLETION_TOKENS=16384
JUDGE_NUM_WORKERS=256
JUDGE_TIMEOUT=3600
JUDGE_FREQUENCY_PENALTY=0
JUDGE_PRESENCE_PENALTY=0
JUDGE_STOP=
JUDGE_SYSTEM_PROMPT=
JUDGE_TOOL_CONFIG=
JUDGE_CALLBACK=
JUDGE_MAX_TURNS=3
JUDGE_ENABLE_MULTITURN=false
JUDGE_RESUME=false
JUDGE_PARALLEL_COUNT=1

# Infra ---------------------------------------------------------------------
OUTPUT_ROOT=
TARGET_PORT=30000
JUDGE_PORT=30001
HEALTH_TIMEOUT=1800
